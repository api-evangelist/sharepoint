{
  "@context": {
    "@version": 1.1,
    "sp": "https://learn.microsoft.com/en-us/sharepoint/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "File": "sp:File",
    "FileCollection": "sp:FileCollection",
    "List": "sp:List",
