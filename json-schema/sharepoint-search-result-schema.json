{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/sharepoint/refs/heads/main/json-schema/sharepoint-search-result-schema.json",
  "title": "SearchResult",
  "description": "SharePoint search results.",
  "type": "object",
  "properties": {
    "PrimaryQueryResult": {
      "type": "object",
      "properties": {
        "RelevantResults": {
          "type": "object",
          "properties": {
            "TotalRows": {
              "type": "integer",
              "example": 42
            },
            "RowCount": {
              "type": "integer",
              "example": 10
            },
            "Table": {
              "type": "object",
              "properties": {
                "Rows": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "Cells": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "Key": {
                              "type": "string",
                              "example": "Title"
                            },
                            "Value": {
                              "type": "string",
                              "example": "Sample Document"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}